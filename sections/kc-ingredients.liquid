{{ 'section-kc-ingredients' | append: '' }}

<style>
  .kc-ingredients {
    background: var(--kc-white, #FFFFFF);
    padding: 80px var(--content-padding, 24px);
  }

  .kc-ingredients__container {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
  }

  .kc-ingredients__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .kc-ingredients__heading {
    font-family: var(--font-heading, 'DM Serif Display', serif);
    font-size: 36px;
    font-weight: 700;
    color: var(--kc-text, #1A1A1A);
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .kc-ingredients__subheading {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 18px;
    color: var(--kc-text-secondary, #555);
    margin: 0 0 20px;
    line-height: 1.5;
  }

  .kc-ingredients__description {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 16px;
    color: var(--kc-text-secondary, #555);
    line-height: 1.7;
    max-width: 700px;
    margin: 0 auto 24px;
  }

  .kc-ingredients__tagline {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 16px;
    font-weight: 600;
    color: var(--kc-blue, #2E7D32);
    margin: 0 0 24px;
  }

  /* Free-From Badges */
  .kc-ingredients__badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-bottom: 48px;
  }

  .kc-ingredients__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--kc-badge-bg, #fffbea);
    color: var(--kc-blue, #2E7D32);
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: 999px;
    white-space: nowrap;
    line-height: 1.4;
  }

  .kc-ingredients__badge-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  .kc-ingredients__badge-icon svg {
    width: 18px;
    height: 18px;
  }

  /* Ingredient Cards Grid */
  .kc-ingredients__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .kc-ingredients__card {
    background: var(--kc-white, #FFFFFF);
    border: 1px solid var(--kc-border, #E5E5E5);
    border-radius: var(--card-radius, 12px);
    padding: 24px;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .kc-ingredients__card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .kc-ingredients__card-image-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 16px;
    background: var(--kc-alt, #F5F5FA);
  }

  .kc-ingredients__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kc-ingredients__card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--kc-text-secondary, #555);
  }

  .kc-ingredients__card-placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.35;
  }

  .kc-ingredients__card-name {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--kc-text, #1A1A1A);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .kc-ingredients__card-desc {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 16px;
    color: var(--kc-text-secondary, #555);
    line-height: 1.6;
    margin: 0;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    .kc-ingredients {
      padding: 48px var(--content-padding, 24px);
    }

    .kc-ingredients__heading {
      font-size: 26px;
    }

    .kc-ingredients__subheading {
      font-size: 16px;
    }

    .kc-ingredients__badges {
      display: grid;
      grid-template-columns: repeat(2, auto);
      justify-content: center;
      gap: 10px;
    }

    .kc-ingredients__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<section class="kc-ingredients" id="ingredients">
  <div class="kc-ingredients__container">
    {%- comment -%} Header Block {%- endcomment -%}
    <div class="kc-ingredients__header">
      <h2 class="kc-ingredients__heading">{{ section.settings.heading }}</h2>
      <p class="kc-ingredients__subheading">{{ section.settings.subheading }}</p>

      {%- if section.settings.description != blank -%}
        <p class="kc-ingredients__description">{{ section.settings.description }}</p>
      {%- endif -%}

      <p class="kc-ingredients__tagline">{{ section.settings.tagline }}</p>

      {%- comment -%} Free-From Badges {%- endcomment -%}
      <div class="kc-ingredients__badges">
        <span class="kc-ingredients__badge">
          <span class="kc-ingredients__badge-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75"/></svg>
          </span>
          Natural Formula
        </span>
        <span class="kc-ingredients__badge">
          <span class="kc-ingredients__badge-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          </span>
          Chemical-Free
        </span>
        <span class="kc-ingredients__badge">
          <span class="kc-ingredients__badge-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </span>
          Non-GMO
        </span>
        <span class="kc-ingredients__badge">
          <span class="kc-ingredients__badge-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
          </span>
          Plant-Based
        </span>
      </div>
    </div>

    {%- comment -%} Ingredient Cards {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="kc-ingredients__grid">
        {%- for block in section.blocks -%}
          <div class="kc-ingredients__card" {{ block.shopify_attributes }}>
            <div class="kc-ingredients__card-image-wrap">
              {%- if block.settings.image != blank -%}
                <img
                  class="kc-ingredients__card-image"
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.name | escape }}"
                  width="600"
                  height="450"
                  loading="lazy"
                >
              {%- else -%}
                <div class="kc-ingredients__card-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>
            <h3 class="kc-ingredients__card-name">{{ block.settings.name }}</h3>
            {%- if block.settings.description != blank -%}
              <p class="kc-ingredients__card-desc">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "KC Ingredients",
  "tag": "section",
  "class": "kc-ingredients-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What's Inside"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Potent, science-backed ingredients"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Each ingredient in KeraClear is carefully selected by dermatologists and podiatrists for its proven ability to restore nail health, fight fungal infection, and promote strong, clear nail growth."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "All the good, none of the bad"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Ingredient image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient name",
          "default": "Ingredient"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Ingredient description",
          "default": "A powerful natural ingredient that supports nail health and restoration."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC Ingredients",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "name": "Tea Tree Oil",
            "description": "A powerful natural antifungal and antiseptic that penetrates the nail bed to eliminate fungal infections at their source while soothing irritated skin."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Undecylenic Acid",
            "description": "An FDA-recognized antifungal compound derived from castor oil that disrupts fungal cell membranes and prevents reinfection for lasting results."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Vitamin E",
            "description": "A potent antioxidant that nourishes damaged nail tissue, accelerates cellular repair, and strengthens brittle nails from the inside out."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Jojoba Oil",
            "description": "A deeply moisturizing carrier oil that mirrors the skin's natural sebum, softening cuticles and delivering active ingredients deep into the nail matrix."
          }
        }
      ]
    }
  ]
}
{% endschema %}
