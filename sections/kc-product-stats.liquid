{{ 'keraclear.css' | asset_url | stylesheet_tag }}

<style>
  .kc-stats {
    background-color: var(--kc-alt, #F5F5FA);
    padding: 60px var(--content-padding, 24px);
  }

  .kc-stats__inner {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
  }

  .kc-stats__heading {
    font-family: var(--font-heading, 'DM Serif Display', serif);
    font-size: 32px;
    font-weight: 700;
    color: var(--kc-text, #1A1A1A);
    text-align: center;
    margin: 0 0 48px 0;
    line-height: 1.2;
  }

  .kc-stats__heading em {
    font-style: italic;
  }

  .kc-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .kc-stats__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 16px 8px;
  }

  .kc-stats__icon {
    width: 28px;
    height: 28px;
    margin-bottom: 12px;
    color: var(--kc-blue, #2E7D32);
  }

  .kc-stats__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .kc-stats__value {
    font-family: var(--font-heading, 'DM Serif Display', serif);
    font-size: 32px;
    font-weight: 700;
    color: var(--kc-blue, #2E7D32);
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .kc-stats__description {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 16px;
    color: var(--kc-text-secondary, #666666);
    line-height: 1.5;
    max-width: 200px;
  }

  .kc-stats__disclaimer {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 13px;
    color: var(--kc-text-secondary, #666666);
    text-align: center;
    margin-top: 48px;
    line-height: 1.5;
  }

  @media screen and (max-width: 991px) {
    .kc-stats__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 28px;
    }
  }

  @media screen and (max-width: 599px) {
    .kc-stats {
      padding: 40px var(--content-padding, 24px);
    }

    .kc-stats__heading {
      font-size: 26px;
      margin-bottom: 36px;
    }

    .kc-stats__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .kc-stats__value {
      font-size: 28px;
    }

    .kc-stats__description {
      font-size: 15px;
    }
  }
</style>

<section class="kc-stats">
  <div class="kc-stats__inner">
    <h2 class="kc-stats__heading">{{ section.settings.heading }}</h2>

    <div class="kc-stats__grid">
      {%- for block in section.blocks -%}
        <div class="kc-stats__card" {{ block.shopify_attributes }}>
          <div class="kc-stats__icon">
            {%- case block.settings.icon -%}
              {%- when 'trending' -%}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                  <polyline points="17 6 23 6 23 12"/>
                </svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <polyline points="9 12 11 14 15 10"/>
                </svg>
              {%- when 'research' -%}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 3h6v2H9z"/>
                  <path d="M10 5v6.5L7 17.5c-.8 1.3.1 3 1.6 3h6.8c1.5 0 2.4-1.7 1.6-3L14 11.5V5"/>
                  <line x1="8" y1="14" x2="16" y2="14"/>
                </svg>
            {%- endcase -%}
          </div>
          <div class="kc-stats__value">{{ block.settings.value }}</div>
          <div class="kc-stats__description">{{ block.settings.description }}</div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.disclaimer != blank -%}
      <p class="kc-stats__disclaimer">{{ section.settings.disclaimer }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "KC Product Stats",
  "tag": "section",
  "class": "kc-product-stats-section",
  "settings": [
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "<em>Real</em> Results"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer Text",
      "default": "*All individuals are unique. Your results can and will vary. Based on a 90-day customer survey."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "trending", "label": "Trending Up" },
            { "value": "star", "label": "Star" },
            { "value": "shield", "label": "Shield" },
            { "value": "research", "label": "Research / Flask" }
          ],
          "default": "trending"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Stat Value",
          "default": "97%"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Reported Visible Improvement"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC Product Stats",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "icon": "trending",
            "value": "97%",
            "description": "Reported Visible Improvement"
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "star",
            "value": "4.8/5",
            "description": "Average Customer Rating"
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "shield",
            "value": "90-Day",
            "description": "Money-Back Guarantee"
          }
        },
        {
          "type": "stat",
          "settings": {
            "icon": "research",
            "value": "25+",
            "description": "Years Clinical Research"
          }
        }
      ]
    }
  ]
}
{% endschema %}
