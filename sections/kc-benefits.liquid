<style>
  .kc-benefits {
    background: #FFFFFF;
    padding: 80px var(--content-padding, 24px);
    position: relative;
    overflow: hidden;
  }

  .kc-benefits__container {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .kc-benefits__image-wrap {
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }

  .kc-benefits__image-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  .kc-benefits__image-placeholder {
    width: 100%;
    aspect-ratio: 3 / 4;
    background: rgba(0,0,0,0.05);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0,0,0,0.4);
    font-size: 16px;
    border: 2px dashed rgba(0,0,0,0.15);
  }

  .kc-benefits__content {}

  .kc-benefits__heading {
    font-family: var(--font-heading, 'DM Serif Display', serif);
    font-size: 32px;
    font-weight: 700;
    color: var(--kc-text, #1A1A1A);
    line-height: 1.2;
    margin: 0 0 32px;
  }

  .kc-benefits__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .kc-benefits__item {
    display: flex;
    align-items: center;
    gap: 14px;
    background: rgba(0,0,0,0.04);
    border-radius: 8px;
    padding: 16px 20px;
    transition: background 0.2s ease;
  }

  .kc-benefits__item:hover {
    background: rgba(0,0,0,0.08);
  }

  .kc-benefits__item-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    line-height: 1;
  }

  .kc-benefits__item-text {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 16px;
    font-weight: 600;
    color: var(--kc-text-secondary, #555);
  }

  @media (max-width: 768px) {
    .kc-benefits {
      padding: 48px var(--content-padding, 24px);
    }

    .kc-benefits__container {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .kc-benefits__heading {
      font-size: 26px;
    }

    .kc-benefits__image-wrap {
      order: -1;
    }
  }
</style>

<section class="kc-benefits" id="benefits">
  <div class="kc-benefits__container">
    <div class="kc-benefits__image-wrap">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400,600,800', sizes: '(max-width: 768px) 100vw, 50vw' }}
      {%- else -%}
        <div class="kc-benefits__image-placeholder">Product image</div>
      {%- endif -%}
    </div>

    <div class="kc-benefits__content">
      <h2 class="kc-benefits__heading">{{ section.settings.heading }}</h2>
      <div class="kc-benefits__list">
        {%- for block in section.blocks -%}
          <div class="kc-benefits__item" {{ block.shopify_attributes }}>
            <span class="kc-benefits__item-icon">{{ block.settings.icon }}</span>
            <span class="kc-benefits__item-text">{{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "KC Benefits",
  "tag": "section",
  "class": "kc-benefits-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "5 Key Benefits for Healthy Nails:"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "🛡️"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Benefit Text",
          "default": "Fights Fungus at the Source"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC Benefits",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "🛡️", "text": "Fights Fungus at the Source" } },
        { "type": "benefit", "settings": { "icon": "💧", "text": "Deep Nail Penetration" } },
        { "type": "benefit", "settings": { "icon": "💪", "text": "Nourishes & Strengthens Nails" } },
        { "type": "benefit", "settings": { "icon": "🔄", "text": "Prevents Recurrence" } },
        { "type": "benefit", "settings": { "icon": "✨", "text": "Restores Nail Clarity" } }
      ]
    }
  ]
}
{% endschema %}
