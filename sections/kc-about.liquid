{% comment %}
  Section: kc-about
  About Dr. Landford — full page section
{% endcomment %}

<style>
  /* ── KC-ABOUT ─────────────────────────────────────── */
  .kc-about * { box-sizing: border-box; margin: 0; padding: 0; }

  .kc-about__section {
    width: 100%;
    padding: 80px 24px;
  }
  .kc-about__section--white { background: #FFFFFF; }
  .kc-about__section--light { background: #F5F5FA; }
  .kc-about__section--blue  { background: #2E7D32; }

  .kc-about__container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Typography ────────────────────────────────────── */
  .kc-about__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #2E7D32;
    margin-bottom: 16px;
  }

  .kc-about__heading {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    color: #1A1A2E;
    line-height: 1.2;
  }
  .kc-about__heading--hero {
    font-size: 48px;
    margin-bottom: 20px;
  }
  .kc-about__heading--section {
    font-size: 40px;
    margin-bottom: 24px;
  }
  .kc-about__heading--white {
    color: #FFFFFF;
  }

  .kc-about__subtext {
    font-family: 'Inter', sans-serif;
    font-size: 20px;
    line-height: 1.6;
    color: #555555;
  }
  .kc-about__subtext--hero {
    font-size: 20px;
    color: #666666;
    max-width: 700px;
  }

  /* ── Hero ───────────────────────────────────────────── */
  .kc-about__hero {
    text-align: center;
    padding: 96px 24px 80px;
  }
  .kc-about__hero .kc-about__container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .kc-about__hero-divider {
    width: 60px;
    height: 4px;
    background: #2E7D32;
    border-radius: 2px;
    margin-top: 32px;
  }

  /* ── Doctor Story (two-column) ─────────────────────── */
  .kc-about__story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .kc-about__photo-wrapper {
    position: relative;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: #E8E8F0;
  }
  .kc-about__photo-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .kc-about__photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #999999;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    gap: 12px;
  }
  .kc-about__photo-placeholder svg {
    opacity: 0.4;
  }

  .kc-about__story-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .kc-about__story-text .kc-about__heading--section {
    margin-bottom: 4px;
  }
  .kc-about__bio-paragraph {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    line-height: 1.75;
    color: #444444;
  }

  /* ── Philosophy Cards ──────────────────────────────── */
  .kc-about__cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 48px;
  }
  .kc-about__card {
    background: #FFFFFF;
    border-radius: 12px;
    padding: 40px 32px;
    text-align: center;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .kc-about__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }
  .kc-about__card-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: #EBF0FB;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
  }
  .kc-about__card-icon svg {
    width: 32px;
    height: 32px;
    color: #2E7D32;
  }
  .kc-about__card-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: #1A1A2E;
    margin-bottom: 14px;
    line-height: 1.3;
  }
  .kc-about__card-desc {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    line-height: 1.7;
    color: #555555;
  }

  /* ── Credentials ───────────────────────────────────── */
  .kc-about__credentials-heading {
    text-align: center;
    margin-bottom: 48px;
  }
  .kc-about__credentials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px 48px;
    max-width: 900px;
    margin: 0 auto;
  }
  .kc-about__credential-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: #F5F5FA;
    border-radius: 12px;
    transition: background 0.2s ease;
  }
  .kc-about__credential-item:hover {
    background: #EEEEF6;
  }
  .kc-about__credential-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    color: #2E7D32;
  }
  .kc-about__credential-text {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 500;
    color: #1A1A2E;
    line-height: 1.4;
  }

  /* ── CTA ────────────────────────────────────────────── */
  .kc-about__cta {
    text-align: center;
  }
  .kc-about__cta-text {
    font-family: 'Inter', sans-serif;
    font-size: 20px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    max-width: 640px;
    margin: 0 auto 40px;
  }
  .kc-about__cta .kc-about__heading--white {
    margin-bottom: 20px;
  }
  .kc-about__cta-button {
    display: inline-block;
    background: #FFFFFF;
    color: #2E7D32;
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 700;
    padding: 18px 48px;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }
  .kc-about__cta-button:hover {
    background: #F0F0F0;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.2);
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 900px) {
    .kc-about__section {
      padding: 48px 20px;
    }
    .kc-about__hero {
      padding: 64px 20px 48px;
    }
    .kc-about__heading--hero {
      font-size: 36px;
    }
    .kc-about__heading--section {
      font-size: 32px;
    }
    .kc-about__subtext--hero {
      font-size: 18px;
    }
    .kc-about__story-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .kc-about__photo-wrapper {
      max-width: 420px;
      margin: 0 auto;
    }
    .kc-about__cards-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-top: 36px;
    }
    .kc-about__credentials-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .kc-about__cta-text {
      font-size: 18px;
    }
    .kc-about__cta-button {
      font-size: 17px;
      padding: 16px 40px;
    }
  }

  @media (max-width: 480px) {
    .kc-about__section {
      padding: 40px 16px;
    }
    .kc-about__hero {
      padding: 48px 16px 40px;
    }
    .kc-about__heading--hero {
      font-size: 30px;
    }
    .kc-about__heading--section {
      font-size: 28px;
    }
    .kc-about__card {
      padding: 32px 24px;
    }
    .kc-about__card-title {
      font-size: 20px;
    }
    .kc-about__card-desc {
      font-size: 16px;
    }
    .kc-about__credential-text {
      font-size: 17px;
    }
  }
</style>

<div class="kc-about">

  {%- comment -%} ── 1. HERO BANNER ── {%- endcomment -%}
  <section class="kc-about__section kc-about__section--light kc-about__hero">
    <div class="kc-about__container">
      <p class="kc-about__eyebrow">{{ section.settings.hero_eyebrow }}</p>
      <h1 class="kc-about__heading kc-about__heading--hero">{{ section.settings.hero_heading }}</h1>
      <p class="kc-about__subtext kc-about__subtext--hero">{{ section.settings.hero_subtext }}</p>
      <div class="kc-about__hero-divider" aria-hidden="true"></div>
    </div>
  </section>

  {%- comment -%} ── 2. DOCTOR STORY ── {%- endcomment -%}
  <section class="kc-about__section kc-about__section--white">
    <div class="kc-about__container">
      <div class="kc-about__story-grid">

        {%- comment -%} Photo column {%- endcomment -%}
        <div class="kc-about__photo-wrapper">
          {%- if section.settings.doctor_photo != blank -%}
            <img
              src="{{ section.settings.doctor_photo | image_url: width: 800 }}"
              alt="{{ section.settings.doctor_photo.alt | default: 'Dr. Landford' }}"
              width="600"
              height="800"
              loading="lazy"
            >
          {%- else -%}
            <div class="kc-about__photo-placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>Doctor Photo</span>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Text column {%- endcomment -%}
        <div class="kc-about__story-text">
          <h2 class="kc-about__heading kc-about__heading--section">{{ section.settings.story_heading }}</h2>
          {%- assign bio_paragraphs = section.settings.bio_text | split: '\n\n' -%}
          {%- for paragraph in bio_paragraphs -%}
            {%- assign trimmed = paragraph | strip -%}
            {%- if trimmed != blank -%}
              <p class="kc-about__bio-paragraph">{{ trimmed }}</p>
            {%- endif -%}
          {%- endfor -%}
        </div>

      </div>
    </div>
  </section>

  {%- comment -%} ── 3. PHILOSOPHY CARDS ── {%- endcomment -%}
  <section class="kc-about__section kc-about__section--light">
    <div class="kc-about__container">
      <h2 class="kc-about__heading kc-about__heading--section" style="text-align:center;">{{ section.settings.philosophy_heading }}</h2>
      <div class="kc-about__cards-grid">

        {%- comment -%} Card 1 — Target / Root Cause {%- endcomment -%}
        <div class="kc-about__card">
          <div class="kc-about__card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <h3 class="kc-about__card-title">{{ section.settings.card_1_title }}</h3>
          <p class="kc-about__card-desc">{{ section.settings.card_1_desc }}</p>
        </div>

        {%- comment -%} Card 2 — Leaf / Natural Science {%- endcomment -%}
        <div class="kc-about__card">
          <div class="kc-about__card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 20 .5 20 .5s-1.2 6-4.4 10.4A7 7 0 0 1 11 20z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
          </div>
          <h3 class="kc-about__card-title">{{ section.settings.card_2_title }}</h3>
          <p class="kc-about__card-desc">{{ section.settings.card_2_desc }}</p>
        </div>

        {%- comment -%} Card 3 — Heart / Patient-First {%- endcomment -%}
        <div class="kc-about__card">
          <div class="kc-about__card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </div>
          <h3 class="kc-about__card-title">{{ section.settings.card_3_title }}</h3>
          <p class="kc-about__card-desc">{{ section.settings.card_3_desc }}</p>
        </div>

      </div>
    </div>
  </section>

  {%- comment -%} ── 4. CREDENTIALS ── {%- endcomment -%}
  <section class="kc-about__section kc-about__section--white">
    <div class="kc-about__container">
      <div class="kc-about__credentials-heading">
        <h2 class="kc-about__heading kc-about__heading--section">{{ section.settings.credentials_heading }}</h2>
      </div>
      <div class="kc-about__credentials-grid">

        {%- assign credentials = section.settings.credential_1
          | append: '||'
          | append: section.settings.credential_2
          | append: '||'
          | append: section.settings.credential_3
          | append: '||'
          | append: section.settings.credential_4
          | append: '||'
          | append: section.settings.credential_5
          | append: '||'
          | append: section.settings.credential_6
        -%}
        {%- assign credential_list = credentials | split: '||' -%}

        {%- for cred in credential_list -%}
          {%- assign cred_trimmed = cred | strip -%}
          {%- if cred_trimmed != blank -%}
            <div class="kc-about__credential-item">
              <svg class="kc-about__credential-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span class="kc-about__credential-text">{{ cred_trimmed }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}

      </div>
    </div>
  </section>

  {%- comment -%} ── 5. CTA ── {%- endcomment -%}
  <section class="kc-about__section kc-about__section--blue">
    <div class="kc-about__container kc-about__cta">
      <h2 class="kc-about__heading kc-about__heading--section kc-about__heading--white">{{ section.settings.cta_heading }}</h2>
      <p class="kc-about__cta-text">{{ section.settings.cta_text }}</p>
      <a href="{{ section.settings.cta_url }}" class="kc-about__cta-button">{{ section.settings.cta_button_text }}</a>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "KC About Dr. Landford",
  "tag": "section",
  "class": "kc-about-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero Banner"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Eyebrow Text",
      "default": "About Dr. Landford"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero Heading",
      "default": "25 Years of Dedication to Nail Health"
    },
    {
      "type": "text",
      "id": "hero_subtext",
      "label": "Hero Subtext",
      "default": "Board-Certified Dermatologist | Fellowship-Trained in Nail Disorders | Published Researcher"
    },
    {
      "type": "header",
      "content": "Doctor Story"
    },
    {
      "type": "image_picker",
      "id": "doctor_photo",
      "label": "Doctor Photo"
    },
    {
      "type": "text",
      "id": "story_heading",
      "label": "Story Heading",
      "default": "The Doctor Behind Keraclear"
    },
    {
      "type": "textarea",
      "id": "bio_text",
      "label": "Bio Text (separate paragraphs with blank lines)",
      "default": "After more than two decades of clinical practice in dermatology, Dr. Landford witnessed a frustrating pattern: patients with nail fungus cycling through treatments that either didn't work or came with harsh side effects.\n\nDriven by his patients' needs, Dr. Landford spent years researching natural compounds with proven antifungal properties. The result was Keraclear — a proprietary formula that combines the most effective natural ingredients in a fast-absorbing oil that penetrates through the nail bed.\n\n\"I created Keraclear because my patients deserved better,\" says Dr. Landford. \"They needed something that was both effective and gentle — something they could trust.\""
    },
    {
      "type": "header",
      "content": "Philosophy Cards"
    },
    {
      "type": "text",
      "id": "philosophy_heading",
      "label": "Philosophy Heading",
      "default": "Dr. Landford's Philosophy"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Card 1 Title",
      "default": "Root Cause Treatment"
    },
    {
      "type": "textarea",
      "id": "card_1_desc",
      "label": "Card 1 Description",
      "default": "Dr. Landford believes in treating the source of the problem, not masking symptoms. Keraclear penetrates through the nail to fight fungus where it lives."
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Card 2 Title",
      "default": "Natural Science"
    },
    {
      "type": "textarea",
      "id": "card_2_desc",
      "label": "Card 2 Description",
      "default": "Every ingredient is clinically studied and naturally derived. No harsh chemicals, no synthetic fillers — just what works, backed by research."
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Card 3 Title",
      "default": "Patient-First Care"
    },
    {
      "type": "textarea",
      "id": "card_3_desc",
      "label": "Card 3 Description",
      "default": "With over 25 years of listening to patients, Dr. Landford designed Keraclear to be simple, gentle, and effective for everyday use."
    },
    {
      "type": "header",
      "content": "Credentials & Affiliations"
    },
    {
      "type": "text",
      "id": "credentials_heading",
      "label": "Credentials Heading",
      "default": "Credentials & Affiliations"
    },
    {
      "type": "text",
      "id": "credential_1",
      "label": "Credential 1",
      "default": "Board-Certified Dermatologist"
    },
    {
      "type": "text",
      "id": "credential_2",
      "label": "Credential 2",
      "default": "25+ Years Clinical Experience"
    },
    {
      "type": "text",
      "id": "credential_3",
      "label": "Credential 3",
      "default": "Fellowship-Trained in Nail Disorders"
    },
    {
      "type": "text",
      "id": "credential_4",
      "label": "Credential 4",
      "default": "Published Researcher in Dermatology"
    },
    {
      "type": "text",
      "id": "credential_5",
      "label": "Credential 5",
      "default": "Member, American Academy of Dermatology"
    },
    {
      "type": "text",
      "id": "credential_6",
      "label": "Credential 6",
      "default": "Member, American Board of Dermatology"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "Experience the Difference"
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Join thousands of satisfied customers who trust Dr. Landford's formula for healthier, clearer nails."
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "CTA Button Text",
      "default": "Shop Keraclear"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL"
    }
  ],
  "presets": [
    {
      "name": "KC About Dr. Landford"
    }
  ]
}
{% endschema %}
