<style>
  .kc-guarantee {
    background-color: #F5EDE3;
    padding: 72px var(--content-padding, 24px);
  }

  .kc-guarantee__inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .kc-guarantee__badge {
    width: 120px;
    height: 120px;
    margin: 0 auto 24px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kc-guarantee__badge-circle {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 4px solid var(--kc-blue, #2E7D32);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #FFFFFF;
    position: relative;
  }

  .kc-guarantee__badge-top {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--kc-blue, #2E7D32);
  }

  .kc-guarantee__badge-number {
    font-family: var(--font-heading, 'Playfair Display', serif);
    font-size: 36px;
    font-weight: 700;
    color: var(--kc-blue, #2E7D32);
    line-height: 1;
  }

  .kc-guarantee__badge-unit {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--kc-blue, #2E7D32);
  }

  .kc-guarantee__badge-bottom {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 8px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--kc-blue, #2E7D32);
  }

  .kc-guarantee__heading {
    font-family: var(--font-heading, 'Playfair Display', serif);
    font-size: 32px;
    font-weight: 700;
    color: var(--kc-text, #1A1A1A);
    margin-bottom: 16px;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .kc-guarantee__text {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 16px;
    color: var(--kc-text-secondary, #666666);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }

  @media screen and (max-width: 749px) {
    .kc-guarantee {
      padding: 48px var(--content-padding, 24px);
    }

    .kc-guarantee__heading {
      font-size: 26px;
    }

    .kc-guarantee__badge-circle {
      width: 100px;
      height: 100px;
    }

    .kc-guarantee__badge-number {
      font-size: 30px;
    }
  }
</style>

<section class="kc-guarantee" data-section-id="{{ section.id }}">
  <div class="kc-guarantee__inner">
    <div class="kc-guarantee__badge">
      <div class="kc-guarantee__badge-circle">
        <span class="kc-guarantee__badge-top">Money Back</span>
        <span class="kc-guarantee__badge-number">90</span>
        <span class="kc-guarantee__badge-unit">Days</span>
        <span class="kc-guarantee__badge-bottom">Guarantee</span>
      </div>
    </div>
    <h2 class="kc-guarantee__heading">{{ section.settings.heading }}</h2>
    <p class="kc-guarantee__text">{{ section.settings.text }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Guarantee",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "90-Day Money-Back Guarantee"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "We'd be shocked if you didn't see the results, and enjoy the benefits of Keraclear. But in the highly unlikely event that you're not happy in any way — we'll give you every cent back. No hassle. No hoops to jump through."
    }
  ],
  "presets": [
    {
      "name": "Guarantee"
    }
  ]
}
{% endschema %}
