<style>
  .kc-guarantee {
    padding: 32px var(--content-padding, 24px);
  }
  .guarantee-box {
    display: flex;
    gap: 20px;
    align-items: center;
    background: #fffbea;
    border: 2px solid #f39c12;
    border-radius: 12px;
    padding: 28px;
    max-width: 700px;
    margin: 0 auto;
  }
  .guarantee-box img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
  }
  .guarantee-text h3 {
    font-family: var(--font-heading, 'DM Serif Display', Georgia, serif);
    font-size: 20px;
    margin-bottom: 8px;
    color: #1a1a1a;
  }
  .guarantee-text p {
    font-size: 15px;
    color: #555;
    margin: 0;
    line-height: 1.6;
  }
  @media (max-width: 600px) {
    .guarantee-box {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<section class="kc-guarantee" data-section-id="{{ section.id }}">
  <div class="guarantee-box">
    {%- if section.settings.badge_image != blank -%}
      <img src="{{ section.settings.badge_image | image_url: width: 160 }}" alt="90-Day Money-Back Guarantee badge">
    {%- else -%}
      <img src="https://cdn.shopify.com/s/files/1/0789/7792/5341/files/hf_20260310_123915_2be997fb-38e5-461f-b8ae-357908c36d86.jpg?v=1773200141" alt="90-Day Money-Back Guarantee badge">
    {%- endif -%}
    <div class="guarantee-text">
      <h3>{{ section.settings.heading }}</h3>
      <p>{{ section.settings.text }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guarantee",
  "settings": [
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Badge image (optional, defaults to gold seal)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "90-Day \u201cClear Nail\u201d Money-Back Guarantee"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Try KeraClear for a full 90 days. If you do not see a visible difference in the clarity, thickness, and health of your nails — send it back for a complete refund. No questions asked. Dr. Langford stands behind every bottle."
    }
  ],
  "presets": [
    {
      "name": "Guarantee"
    }
  ]
}
{% endschema %}
