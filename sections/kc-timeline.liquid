<style>
  .kc-timeline {
    background: var(--kc-white, #FFFFFF);
    padding: 80px var(--content-padding, 24px);
  }

  .kc-timeline__container {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .kc-timeline__image-wrap {
    border-radius: 12px;
    overflow: hidden;
    background: #111;
  }

  .kc-timeline__image-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  .kc-timeline__image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--kc-alt, #F5F5FA);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--kc-text-secondary, #666666);
    font-size: 16px;
    border: 2px dashed var(--kc-border, #E5E5E5);
  }

  .kc-timeline__content {}

  .kc-timeline__heading {
    font-family: var(--font-heading, 'Playfair Display', serif);
    font-size: 32px;
    font-weight: 700;
    color: var(--kc-text, #1A1A1A);
    line-height: 1.2;
    margin: 0 0 32px;
    text-transform: uppercase;
  }

  .kc-timeline__heading em {
    font-style: normal;
    color: var(--kc-blue, #2E7D32);
  }

  .kc-timeline__days {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 32px;
  }

  .kc-timeline__day {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .kc-timeline__day-label {
    flex-shrink: 0;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 15px;
    font-weight: 800;
    color: var(--kc-blue, #2E7D32);
    min-width: 60px;
  }

  .kc-timeline__day-icon {
    font-size: 18px;
    line-height: 1;
    flex-shrink: 0;
  }

  .kc-timeline__day-text {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 15px;
    color: var(--kc-text, #1A1A1A);
    line-height: 1.5;
  }

  .kc-timeline__outro {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 16px;
    color: var(--kc-text, #1A1A1A);
    line-height: 1.6;
  }

  .kc-timeline__outro strong {
    display: block;
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .kc-timeline {
      padding: 48px var(--content-padding, 24px);
    }

    .kc-timeline__container {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .kc-timeline__heading {
      font-size: 26px;
    }

    .kc-timeline__image-wrap {
      order: -1;
    }
  }
</style>

<section class="kc-timeline" id="timeline">
  <div class="kc-timeline__container">
    <div class="kc-timeline__image-wrap">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '400,600,800', sizes: '(max-width: 768px) 100vw, 50vw' }}
      {%- else -%}
        <div class="kc-timeline__image-placeholder">Before / After image</div>
      {%- endif -%}
    </div>

    <div class="kc-timeline__content">
      <h2 class="kc-timeline__heading">{{ section.settings.heading }}</h2>

      <div class="kc-timeline__days">
        {%- for block in section.blocks -%}
          <div class="kc-timeline__day" {{ block.shopify_attributes }}>
            <span class="kc-timeline__day-icon">📅</span>
            <span class="kc-timeline__day-label">{{ block.settings.day }}</span>
            <span class="kc-timeline__day-text">– {{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.outro != blank -%}
        <div class="kc-timeline__outro">{{ section.settings.outro }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "KC Timeline",
  "tag": "section",
  "class": "kc-timeline-section",
  "settings": [
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "What You'll See — <em>Day by Day.</em> From Fungus to Clear — Fast."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Before/After Image"
    },
    {
      "type": "richtext",
      "id": "outro",
      "label": "Outro Text",
      "default": "<p>This isn't a cover-up.<br><strong>It's a clear-out.</strong></p>"
    }
  ],
  "blocks": [
    {
      "type": "day",
      "name": "Day",
      "settings": [
        {
          "type": "text",
          "id": "day",
          "label": "Day Label",
          "default": "Day 1"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Serum absorbs quickly. Nails feel hydrated. Something shifts."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC Timeline",
      "blocks": [
        { "type": "day", "settings": { "day": "Day 1", "text": "Serum absorbs quickly. Nails feel hydrated. Something shifts." } },
        { "type": "day", "settings": { "day": "Day 7", "text": "Nail bed feels cleaner. Discoloration begins to lighten." } },
        { "type": "day", "settings": { "day": "Day 14", "text": "New clear nail growth visible at the base. Texture improving." } },
        { "type": "day", "settings": { "day": "Day 30", "text": "Significant improvement in nail clarity and strength." } },
        { "type": "day", "settings": { "day": "Day 60", "text": "Fungus-free growth continues. Confidence returns." } },
        { "type": "day", "settings": { "day": "Day 90", "text": "Healthy, clear nails. The transformation is complete." } }
      ]
    }
  ]
}
{% endschema %}
