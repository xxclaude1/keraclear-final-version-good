<style>
  .kc-rec {
    background-color: var(--kc-white);
    padding: 80px 0;
  }

  .kc-rec__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
  }

  .kc-rec__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .kc-rec__heading {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 700;
    color: var(--kc-text);
    line-height: 1.2;
    margin: 0 0 12px;
  }

  .kc-rec__subheading {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 18px;
    color: var(--kc-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* Featured product card */
  .kc-rec__card {
    max-width: 800px;
    margin: 0 auto;
    background-color: var(--kc-white);
    border: 1px solid var(--kc-border);
    border-radius: var(--card-radius);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .kc-rec__card-image {
    position: relative;
    background-color: var(--kc-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
    overflow: hidden;
  }

  .kc-rec__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .kc-rec__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background-color: var(--kc-blue);
    color: var(--kc-white);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.5px;
    padding: 6px 16px;
    border-radius: 999px;
    text-transform: uppercase;
    z-index: 2;
  }

  .kc-rec__card-body {
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
  }

  .kc-rec__product-title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 700;
    color: var(--kc-text);
    line-height: 1.3;
    margin: 0;
  }

  .kc-rec__product-subtitle {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--kc-text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* Star rating row */
  .kc-rec__rating {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .kc-rec__stars {
    display: flex;
    gap: 2px;
  }

  .kc-rec__star {
    color: var(--kc-star);
    font-size: 18px;
    line-height: 1;
  }

  .kc-rec__review-count {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--kc-text-secondary);
    line-height: 1;
  }

  /* Price row */
  .kc-rec__price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  .kc-rec__price {
    font-family: var(--font-body);
    font-size: 32px;
    font-weight: 800;
    color: var(--kc-text);
    line-height: 1;
  }

  .kc-rec__compare-price {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--kc-text-secondary);
    text-decoration: line-through;
    line-height: 1;
  }

  .kc-rec__shipping-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background-color: var(--kc-badge-bg);
    color: var(--kc-blue);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    width: fit-content;
  }

  .kc-rec__shipping-badge svg {
    flex-shrink: 0;
  }

  /* CTA button */
  .kc-rec__cta {
    display: block;
    width: 100%;
    background-color: var(--kc-blue);
    color: var(--kc-white);
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 16px 24px;
    border: none;
    border-radius: var(--btn-radius);
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .kc-rec__cta:hover {
    background-color: var(--kc-blue-hover);
  }

  /* Doctor quote */
  .kc-rec__quote {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 16px;
    color: var(--kc-text-secondary);
    line-height: 1.6;
    margin: 0;
    padding-top: 4px;
    border-top: 1px solid var(--kc-border);
  }

  .kc-rec__quote-attribution {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 600;
    font-size: 14px;
    color: var(--kc-text);
    display: block;
    margin-top: 6px;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .kc-rec {
      padding: 48px 0;
    }

    .kc-rec__heading {
      font-size: 26px;
    }

    .kc-rec__subheading {
      font-size: 16px;
    }

    .kc-rec__card {
      grid-template-columns: 1fr;
    }

    .kc-rec__card-image {
      min-height: 300px;
    }

    .kc-rec__card-body {
      padding: 28px 24px;
    }

    .kc-rec__product-title {
      font-size: 22px;
    }

    .kc-rec__price {
      font-size: 28px;
    }

    .kc-rec__cta {
      font-size: 16px;
      padding: 14px 20px;
    }
  }
</style>

<section class="kc-rec" id="recommendations">
  <div class="kc-rec__inner">
    {%- comment -%} Section header {%- endcomment -%}
    <div class="kc-rec__header">
      <h2 class="kc-rec__heading">{{ section.settings.heading }}</h2>
      <p class="kc-rec__subheading">{{ section.settings.subheading }}</p>
    </div>

    {%- comment -%} Featured product card {%- endcomment -%}
    <div class="kc-rec__card">
      {%- comment -%} Image side {%- endcomment -%}
      <div class="kc-rec__card-image">
        <span class="kc-rec__badge">{{ section.settings.badge_text }}</span>
        {%- if section.settings.product_image != blank -%}
          <img
            src="{{ section.settings.product_image | image_url: width: 800 }}"
            alt="{{ section.settings.product_title | escape }}"
            loading="lazy"
            width="800"
            height="800"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      {%- comment -%} Details side {%- endcomment -%}
      <div class="kc-rec__card-body">
        <h3 class="kc-rec__product-title">{{ section.settings.product_title }}</h3>
        <p class="kc-rec__product-subtitle">{{ section.settings.product_subtitle }}</p>

        {%- comment -%} Star rating {%- endcomment -%}
        <div class="kc-rec__rating">
          <div class="kc-rec__stars" aria-hidden="true">
            {%- for i in (1..5) -%}
              <span class="kc-rec__star">&#9733;</span>
            {%- endfor -%}
          </div>
          <span class="kc-rec__review-count">{{ section.settings.review_count }}</span>
        </div>

        {%- comment -%} Pricing {%- endcomment -%}
        <div class="kc-rec__price-row">
          <span class="kc-rec__price">{{ section.settings.price }}</span>
          {%- if section.settings.compare_price != blank -%}
            <span class="kc-rec__compare-price">{{ section.settings.compare_price }}</span>
          {%- endif -%}
        </div>

        {%- comment -%} Free shipping badge {%- endcomment -%}
        {%- if section.settings.show_free_shipping -%}
          <div class="kc-rec__shipping-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {{ section.settings.shipping_text }}
          </div>
        {%- endif -%}

        {%- comment -%} CTA button {%- endcomment -%}
        <a
          class="kc-rec__cta"
          href="{{ section.settings.button_link }}"
          aria-label="{{ section.settings.button_text }} — {{ section.settings.product_title }}"
        >
          {{ section.settings.button_text }}
        </a>

        {%- comment -%} Doctor quote {%- endcomment -%}
        {%- if section.settings.doctor_quote != blank -%}
          <p class="kc-rec__quote">
            "{{ section.settings.doctor_quote }}"
            <span class="kc-rec__quote-attribution">— {{ section.settings.doctor_name }}</span>
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dr. Recommendations",
  "tag": "section",
  "class": "kc-recommendations-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dr. Landford Recommends"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "His top pick for fighting nail fungus"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Best Seller"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Product title",
      "default": "Keraclear — 3 Bottles"
    },
    {
      "type": "text",
      "id": "product_subtitle",
      "label": "Product subtitle",
      "default": "90-day supply — Our most popular package"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count text",
      "default": "14,576 Reviews"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Sale price",
      "default": "$207"
    },
    {
      "type": "text",
      "id": "compare_price",
      "label": "Compare-at price",
      "default": "$537"
    },
    {
      "type": "checkbox",
      "id": "show_free_shipping",
      "label": "Show free shipping badge",
      "default": true
    },
    {
      "type": "text",
      "id": "shipping_text",
      "label": "Shipping badge text",
      "default": "FREE SHIPPING"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "textarea",
      "id": "doctor_quote",
      "label": "Doctor quote",
      "default": "The 90-day supply gives your nails the full treatment cycle they need."
    },
    {
      "type": "text",
      "id": "doctor_name",
      "label": "Doctor name",
      "default": "Dr. Landford"
    }
  ],
  "presets": [
    {
      "name": "Dr. Recommendations"
    }
  ]
}
{% endschema %}
