            "badge": "Best Seller",
            "review_count": "14,576 Reviews"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "title": "Keraclear — 6 Bottles",
            "description": "180-day supply. Maximum savings for the full treatment cycle.",
            "price": "294",
            "compare_price": "1,074",
            "badge": "Best Value",
            "review_count": "14,576 Reviews"
