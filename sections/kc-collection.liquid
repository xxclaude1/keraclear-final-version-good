<style>
  .kc-collection {
    background-color: var(--kc-navy);
    color: var(--kc-white);
    padding: 80px 0;
  }

  .kc-collection__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
  }

  /* Top area: doctor + heading */
  .kc-collection__top {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 40px;
    align-items: center;
    margin-bottom: 48px;
  }

  .kc-collection__doctor-img {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(255, 255, 255, 0.2);
  }

  .kc-collection__doctor-placeholder {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 13px;
    text-align: center;
    border: 3px solid rgba(255, 255, 255, 0.2);
  }

  .kc-collection__heading {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    color: var(--kc-white);
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .kc-collection__quote {
    font-style: italic;
    font-size: 17px;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
  }

  /* Product cards grid */
  .kc-collection__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }

  .kc-collection__card {
    background-color: var(--kc-white);
    border-radius: var(--card-radius);
    padding: 24px;
    display: flex;
    flex-direction: column;
    position: relative;
    color: var(--kc-text);
  }

  .kc-collection__card-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    padding: 4px 12px;
    font-size: 11px;
    font-weight: 700;
    border-radius: 20px;
    background-color: var(--kc-badge-bg);
    color: var(--kc-blue);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .kc-collection__card-image-wrapper {
    background-color: var(--kc-alt);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 180px;
  }

  .kc-collection__card-image {
    max-height: 160px;
    width: auto;
    max-width: 100%;
  }

  .kc-collection__card-image-ph {
    color: var(--kc-text-secondary);
    font-size: 14px;
  }

  .kc-collection__card-name {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    color: var(--kc-text);
    margin-bottom: 4px;
  }

  .kc-collection__card-stars {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 8px;
  }

  .kc-collection__card-stars svg {
    width: 14px;
    height: 14px;
    fill: var(--kc-star);
  }

  .kc-collection__card-stars span {
    font-size: 13px;
    color: var(--kc-text-secondary);
  }

  .kc-collection__card-desc {
    font-size: 15px;
    color: var(--kc-text-secondary);
    line-height: 1.5;
    margin-bottom: 16px;
    flex-grow: 1;
  }

  .kc-collection__card-pricing {
    margin-bottom: 16px;
  }

  .kc-collection__card-compare {
    font-size: 14px;
    color: var(--kc-text-secondary);
    text-decoration: line-through;
    margin-bottom: 2px;
  }

  .kc-collection__card-price {
    font-size: 24px;
    font-weight: 700;
    color: var(--kc-text);
  }

  .kc-collection__card-btn {
    display: block;
    width: 100%;
    padding: 14px 24px;
    background-color: var(--kc-blue);
    color: var(--kc-white);
    border: none;
    border-radius: var(--btn-radius);
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: background-color 0.2s ease;
    text-decoration: none;
    min-height: 48px;
  }

  .kc-collection__card-btn:hover {
    background-color: var(--kc-blue-hover);
    color: var(--kc-white);
  }

  /* Shop all link */
  .kc-collection__shop-all {
    text-align: center;
  }

  .kc-collection__shop-all a {
    font-size: 16px;
    font-weight: 600;
    color: var(--kc-white);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .kc-collection__shop-all a:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 989px) {
    .kc-collection__cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .kc-collection {
      padding: 48px 0;
    }

    .kc-collection__top {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 20px;
    }

    .kc-collection__doctor-img,
    .kc-collection__doctor-placeholder {
      margin: 0 auto;
      width: 96px;
      height: 96px;
    }

    .kc-collection__heading {
      font-size: 26px;
    }

    .kc-collection__cards {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>

<section class="kc-collection" data-section-id="{{ section.id }}">
  <div class="kc-collection__inner">
    <!-- Doctor + heading -->
    <div class="kc-collection__top">
      <div>
        {%- if section.settings.doctor_image != blank -%}
          <img
            src="{{ section.settings.doctor_image | image_url: width: 240 }}"
            alt="Dr. Landford"
            class="kc-collection__doctor-img"
            width="120"
            height="120"
            loading="lazy"
          >
        {%- else -%}
          <div class="kc-collection__doctor-placeholder">Photo</div>
        {%- endif -%}
      </div>
      <div>
        <h2 class="kc-collection__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.quote != blank -%}
          <p class="kc-collection__quote">"{{ section.settings.quote }}"</p>
        {%- endif -%}
      </div>
    </div>

    <!-- Product cards -->
    <div class="kc-collection__cards">
      {%- for block in section.blocks -%}
        <div class="kc-collection__card" {{ block.shopify_attributes }}>
          {%- if block.settings.badge != blank -%}
            <span class="kc-collection__card-badge">{{ block.settings.badge }}</span>
          {%- endif -%}

          <div class="kc-collection__card-image-wrapper">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.title }}"
                class="kc-collection__card-image"
                width="200"
                height="160"
                loading="lazy"
              >
            {%- else -%}
              <span class="kc-collection__card-image-ph">Product image</span>
            {%- endif -%}
          </div>

          <h3 class="kc-collection__card-name">{{ block.settings.title }}</h3>

          <div class="kc-collection__card-stars">
            {%- for i in (1..5) -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- endfor -%}
            <span>{{ block.settings.review_count }}</span>
          </div>

          <p class="kc-collection__card-desc">{{ block.settings.description }}</p>

          <div class="kc-collection__card-pricing">
            {%- if block.settings.compare_price != blank -%}
              <div class="kc-collection__card-compare">Regular Price: ${{ block.settings.compare_price }}</div>
            {%- endif -%}
            <div class="kc-collection__card-price">${{ block.settings.price }}</div>
          </div>

          <a href="{{ block.settings.url | default: '/products/keraclear-antifungal-nail-serum' }}" class="kc-collection__card-btn">Shop Now</a>
        </div>
      {%- endfor -%}
    </div>

    <div class="kc-collection__shop-all">
      <a href="/products/keraclear-antifungal-nail-serum">Shop All &rarr;</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dr. Landford's Nail Health Collection"
    },
    {
      "type": "text",
      "id": "quote",
      "label": "Doctor quote",
