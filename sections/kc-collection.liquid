        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "207"
        },
        {
          "type": "text",
          "id": "compare_price",
          "label": "Compare-at price",
          "default": "537"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text (optional)"
        },
        {
          "type": "text",
          "id": "review_count",
          "label": "Review count text",
          "default": "14,576 Reviews"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
