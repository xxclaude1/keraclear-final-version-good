<style>
  .kc-product-reviews {
    background: var(--kc-white, #FFFFFF);
    padding: 80px var(--content-padding, 24px);
  }

  .kc-product-reviews__container {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
  }

  .kc-product-reviews__heading {
    font-family: var(--font-heading, 'DM Serif Display', serif);
    font-size: 36px;
    font-weight: 700;
    color: var(--kc-text, #1A1A1A);
    text-align: center;
    margin: 0 0 48px;
    line-height: 1.2;
  }

  /* Horizontal scroll */
  .kc-product-reviews__scroll {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 16px;
    scrollbar-width: thin;
  }

  .kc-product-reviews__scroll::-webkit-scrollbar {
    height: 6px;
  }

  .kc-product-reviews__scroll::-webkit-scrollbar-track {
    background: var(--kc-alt, #F5F5FA);
    border-radius: 3px;
  }

  .kc-product-reviews__scroll::-webkit-scrollbar-thumb {
    background: var(--kc-border, #E5E5E5);
    border-radius: 3px;
  }

  .kc-product-reviews__card {
    flex: 0 0 340px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
  }

  .kc-product-reviews__card-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 12px 12px 0 0;
    overflow: hidden;
    background: var(--kc-alt, #F5F5FA);
  }

  .kc-product-reviews__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kc-product-reviews__card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--kc-text-secondary, #555);
    font-size: 14px;
  }

  .kc-product-reviews__card-body {
    padding: 20px;
    flex: 1;
  }

  .kc-product-reviews__card-name {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 16px;
    font-weight: 700;
    color: var(--kc-text, #1A1A1A);
    margin: 0 0 4px;
  }

  .kc-product-reviews__card-title {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 15px;
    font-weight: 600;
    color: var(--kc-text, #1A1A1A);
    margin: 0 0 8px;
  }

  .kc-product-reviews__card-text {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 14px;
    line-height: 1.6;
    color: var(--kc-text-secondary, #555);
    margin: 0 0 12px;
  }

  .kc-product-reviews__card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .kc-product-reviews__card-tag {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 12px;
    color: #b8860b;
    background: #fffbea;
    padding: 4px 10px;
    border-radius: 100px;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .kc-product-reviews {
      padding: 48px var(--content-padding, 24px);
    }

    .kc-product-reviews__heading {
      font-size: 26px;
      margin-bottom: 32px;
    }

    .kc-product-reviews__card {
      flex: 0 0 280px;
    }
  }
</style>

<section class="kc-product-reviews" id="reviews">
  <div class="kc-product-reviews__container">
    <h2 class="kc-product-reviews__heading">{{ section.settings.heading }}</h2>

    <div class="kc-product-reviews__scroll">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <div class="kc-product-reviews__card" {{ block.shopify_attributes }}>
            <div class="kc-product-reviews__card-image">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 680 }}"
                  alt="{{ block.settings.name | escape }}"
                  width="340"
                  height="340"
                  loading="lazy"
                >
              {%- else -%}
                <div class="kc-product-reviews__card-image-placeholder">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
              {%- endif -%}
            </div>
            <div class="kc-product-reviews__card-body">
              <p class="kc-product-reviews__card-name">{{ block.settings.name }}</p>
              <div style="color:#f39c12;font-size:16px;letter-spacing:2px;margin-bottom:8px;">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              <p class="kc-product-reviews__card-title">{{ block.settings.title }}</p>
              <p class="kc-product-reviews__card-text">{{ block.settings.text }}</p>
              {%- if block.settings.tags != blank -%}
                <div class="kc-product-reviews__card-tags">
                  {%- assign tags = block.settings.tags | split: ',' -%}
                  {%- for tag in tags -%}
                    <span class="kc-product-reviews__card-tag">{{ tag | strip }}</span>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "KC Product Reviews",
  "tag": "section",
  "class": "kc-product-reviews-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Story of Our Keraclear Lovers"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Review Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer Name",
          "default": "Happy Customer"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review Title",
          "default": "Great product"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "This product exceeded my expectations."
        },
        {
          "type": "text",
          "id": "tags",
          "label": "Tags (comma separated)",
          "default": "Easy to use, Effective formula"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC Product Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "name": "Robert M.",
            "title": "Finally something that works!",
            "text": "I've tried everything — pills, creams, even vinegar soaks. After 6 weeks of Keraclear, I could see new clear nail growth. Month 3 now and my nails look better than they have in years.",
            "tags": "Easy to apply, Visible results, No mess"
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Patricia K.",
            "title": "Wish I found this sooner",
            "text": "I was embarrassed to wear sandals for 5 years. Keraclear was the perfect alternative — natural ingredients, easy to apply, and it actually delivered results. My confidence is back!",
            "tags": "Natural ingredients, Gentle formula"
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "Sandra L.",
            "title": "The best nail treatment I've used",
            "text": "As a nurse on my feet all day, I was skeptical. But Keraclear's oil formula absorbs so much better than creams. After 8 weeks, the discoloration is almost completely gone.",
            "tags": "Fast absorbing, Strong results"
          }
        },
        {
          "type": "review",
          "settings": {
            "name": "James H.",
            "title": "Slow but steady improvement",
            "text": "It took a full 8 weeks before I noticed changes, but the improvement has been consistent. The oil absorbs quickly which I appreciate. Going to continue with the 6-bottle package.",
            "tags": "Part of daily routine, Consistent results"
          }
        }
      ]
    }
  ]
}
{% endschema %}
