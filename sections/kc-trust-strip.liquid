<style>
  .kc-trust-strip {
    background: var(--kc-blue, #2E7D32);
    padding: 16px var(--content-padding, 24px);
  }

  .kc-trust-strip__inner {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 24px;
    flex-wrap: wrap;
  }

  .kc-trust-strip__item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 14px;
    font-weight: 600;
    color: #FFFFFF;
    white-space: nowrap;
  }

  .kc-trust-strip__check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .kc-trust-strip__check svg {
    width: 12px;
    height: 12px;
    fill: none;
    stroke: #FFFFFF;
    stroke-width: 3;
  }

  @media (max-width: 768px) {
    .kc-trust-strip__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px 20px;
      justify-items: start;
    }

    .kc-trust-strip__item {
      font-size: 13px;
    }
  }
</style>

<section class="kc-trust-strip">
  <div class="kc-trust-strip__inner">
    {%- for block in section.blocks -%}
      <div class="kc-trust-strip__item" {{ block.shopify_attributes }}>
        <span class="kc-trust-strip__check">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        {{ block.settings.text }}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "KC Trust Strip",
  "tag": "section",
  "class": "kc-trust-strip-section",
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Made in USA"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KC Trust Strip",
      "blocks": [
        { "type": "item", "settings": { "text": "Made in USA" } },
        { "type": "item", "settings": { "text": "Doctor-Formulated" } },
        { "type": "item", "settings": { "text": "Fast-absorbing oil formula" } },
        { "type": "item", "settings": { "text": "100% natural ingredients" } }
      ]
    }
  ]
}
{% endschema %}
